---
import { docsNav } from '../data/navigation';

const { pathname } = Astro.url;
const currentSlug = pathname.replace(/^\/docs\/?/, '').replace(/\/$/, '');
---

<aside id="docs-sidebar" class="w-64 flex-shrink-0 hidden lg:block">
  <nav class="sticky top-20 max-h-[calc(100vh-6rem)] overflow-y-auto pr-4 pb-8">
    {docsNav.map((group) => (
      <div class="mb-6">
        <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2 px-2">
          {group.group}
        </h3>
        <ul class="space-y-0.5">
          {group.items.map((item) => {
            const isActive = currentSlug === item.slug;
            return (
              <li>
                <a
                  href={`/docs/${item.slug}`}
                  class:list={[
                    "block px-2 py-1.5 text-sm rounded-md transition-colors",
                    isActive
                      ? "bg-sky-500/10 text-sky-400 font-medium"
                      : "text-slate-400 hover:text-slate-200 hover:bg-slate-800/50"
                  ]}
                >
                  {item.title}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </nav>
</aside>

<!-- Mobile sidebar toggle -->
<button
  id="docs-sidebar-toggle"
  class="lg:hidden fixed bottom-4 right-4 z-40 w-12 h-12 bg-sky-500 hover:bg-sky-400 text-slate-950 rounded-full shadow-lg flex items-center justify-center transition-colors"
  aria-label="Toggle docs sidebar"
>
  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
  </svg>
</button>

<!-- Mobile sidebar overlay -->
<div id="docs-sidebar-overlay" class="hidden fixed inset-0 z-40 lg:hidden">
  <div class="absolute inset-0 bg-slate-950/80 backdrop-blur-sm" id="docs-sidebar-backdrop"></div>
  <nav class="absolute left-0 top-0 bottom-0 w-72 bg-slate-900 border-r border-slate-800 p-6 overflow-y-auto">
    <div class="flex items-center justify-between mb-6">
      <span class="text-sm font-semibold text-slate-200">Documentation</span>
      <button id="docs-sidebar-close" class="text-slate-500 hover:text-slate-300">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    {docsNav.map((group) => (
      <div class="mb-6">
        <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">
          {group.group}
        </h3>
        <ul class="space-y-0.5">
          {group.items.map((item) => {
            const isActive = currentSlug === item.slug;
            return (
              <li>
                <a
                  href={`/docs/${item.slug}`}
                  class:list={[
                    "block px-2 py-1.5 text-sm rounded-md transition-colors",
                    isActive
                      ? "bg-sky-500/10 text-sky-400 font-medium"
                      : "text-slate-400 hover:text-slate-200 hover:bg-slate-800/50"
                  ]}
                >
                  {item.title}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </nav>
</div>

<script>
  const toggle = document.getElementById('docs-sidebar-toggle');
  const overlay = document.getElementById('docs-sidebar-overlay');
  const backdrop = document.getElementById('docs-sidebar-backdrop');
  const close = document.getElementById('docs-sidebar-close');

  function openSidebar() { overlay?.classList.remove('hidden'); }
  function closeSidebar() { overlay?.classList.add('hidden'); }

  toggle?.addEventListener('click', openSidebar);
  backdrop?.addEventListener('click', closeSidebar);
  close?.addEventListener('click', closeSidebar);
</script>
