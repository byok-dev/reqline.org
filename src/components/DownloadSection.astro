---
import { RELEASE_URL } from '../data/urls';

const platforms = [
  {
    name: "macOS",
    format: ".dmg",
    icon: `<path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>`,
    note: "Universal binary (Intel + Apple Silicon)",
  },
  {
    name: "Windows",
    format: ".exe",
    icon: `<path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/>`,
    // note: "Windows 10 or later",
    note: "coming soon",
  },
  {
    name: "Linux",
    format: ".AppImage",
    icon: `<path d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489a.424.424 0 00-.11.135c-.26.268-.45.6-.663.839-.199.199-.485.267-.797.4-.313.136-.658.269-.864.68-.09.189-.136.394-.132.602 0 .199.027.4.055.536.058.399.116.728.04.97-.249.68-.28 1.145-.106 1.484.174.334.535.47.94.601.81.2 1.91.135 2.774.6.926.466 1.866.67 2.616.47.526-.116.97-.464 1.208-.946.587-.003 1.23-.269 2.26-.334.699-.058 1.574.267 2.577.2.025.134.063.198.114.333l.003.003c.391.778 1.113 1.368 1.884 1.43.39.033.77-.396 1.04-.678.27-.282.458-.556.72-.752.132-.086.282-.188.404-.336a1.03 1.03 0 00.196-.353c.038-.135.057-.309.025-.528-.032-.218-.126-.469-.316-.706-.096-.116-.228-.224-.378-.4-.09-.1-.188-.2-.287-.4-.197-.332-.16-.676-.252-1.134-.043-.195-.12-.417-.265-.651-.246-.04-.26-.04-.25-.036-.16-.334-.546-.563-.755-.598a.277.277 0 01.001-.002c-.354-.472-.597-.2-1.066-.37-.32-.07-.6-.198-.89-.398-.29-.202-.58-.455-.892-.735-.652-.573-1.252-1.217-1.674-1.768a4.3 4.3 0 01-.603-.98 2.71 2.71 0 01-.164-.485c-.045-.195-.075-.39-.058-.57.06-.52.218-.99.358-1.487.276-.984.484-2.078.236-3.457-.244-1.358-.685-2.16-1.268-2.744A3.94 3.94 0 0012.504 0z"/>`,
    // note: "AppImage for all distributions",
    note: "Coming soon",
  },
];
---

<section
  class="py-20 bg-gradient-to-b from-transparent via-sky-500/3 to-transparent"
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-100">
        Download Reqline
      </h2>
      <p class="mt-3 text-lg text-slate-400">
        Available for macOS, Windows, and Linux. Free and open source.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
      {
        platforms.map((platform) => (
          <a
            href={RELEASE_URL}
            target="_blank"
            rel="noopener noreferrer"

            class={`group flex flex-col items-center bg-slate-900/50 border border-slate-800/60 hover:border-sky-500/40 rounded-xl p-8 transition-all hover:bg-slate-900/80 ${platform.name !== "macOS" ? "pointer-events-none opacity-50" : ""}`}
          >
            <div class="w-12 h-12 bg-slate-800 group-hover:bg-sky-500/10 rounded-xl flex items-center justify-center mb-4 transition-colors">
              <svg
                class="w-6 h-6 text-slate-400 group-hover:text-sky-400 transition-colors"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <Fragment set:html={platform.icon} />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-slate-200 mb-1">
              {platform.name}
            </h3>
            <span class="text-xs font-mono text-slate-500 mb-3">
              {platform.format}
            </span>
            <p class="text-xs text-slate-500 text-center">{platform.note}</p>
          </a>
        ))
      }
    </div>
  </div>
</section>
