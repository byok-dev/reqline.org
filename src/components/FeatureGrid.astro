---
const features = [
  {
    title: '9 HTTP Methods',
    description: 'Full support for GET, POST, PUT, PATCH, DELETE, HEAD, OPTIONS, CONNECT, and TRACE.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />`,
  },
  {
    title: 'Authentication',
    description: 'Bearer Token, Basic Auth, and API Key (header or query param) built right in.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />`,
  },
  {
    title: 'Environments',
    description: 'Define variables per environment and use {{variable}} syntax anywhere in your requests.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />`,
  },
  {
    title: 'cURL Import',
    description: 'Paste any cURL command directly into the URL bar. Method, headers, body, and auth are auto-detected.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />`,
  },
  {
    title: 'Collections',
    description: 'Organize requests into collections. Pin favorites, reorder with drag-and-drop, and run in bulk.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />`,
  },
  {
    title: 'MCP Integration',
    description: 'Built-in MCP server lets AI agents like Claude, Cursor, and Warp manage your API workflows.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />`,
  },
];
---

<section id="features" class="py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-100">Everything you need, nothing you don't</h2>
      <p class="mt-3 text-lg text-slate-400">Focused tools for API testing without the bloat.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {features.map((feature) => (
        <div class="group bg-slate-900/50 border border-slate-800/60 hover:border-slate-700 rounded-xl p-6 transition-colors">
          <div class="w-10 h-10 bg-sky-500/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <Fragment set:html={feature.icon} />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-200 mb-2">{feature.title}</h3>
          <p class="text-sm text-slate-400 leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
