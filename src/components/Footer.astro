---
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-800/60 bg-slate-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <div>
        <div class="flex items-center gap-2 mb-4">
          <img src="/images/logo.svg" alt="Reqline" class="w-6 h-6 rounded" />
          <span class="font-semibold text-slate-200">Reqline</span>
        </div>
        <p class="text-sm text-slate-500">
          A lightweight API client for testing and debugging HTTP requests.
        </p>
      </div>

      <div>
        <h3
          class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3"
        >
          Product
        </h3>
        <ul class="space-y-2">
          <li>
            <a
              href="/#features"
              class="text-sm text-slate-500 hover:text-slate-300 transition-colors"
              >Features</a>
          </li>
          <li>
            <a
              href="https://github.com/abhi16z/ApiUnravel/releases"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-slate-500 hover:text-slate-300 transition-colors"
              >Download</a>
          </li>
        </ul>
      </div>

      <div>
        <h3
          class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3"
        >
          Docs
        </h3>
        <ul class="space-y-2">
          <li>
            <a
              href="/docs/installation"
              class="text-sm text-slate-500 hover:text-slate-300 transition-colors"
              >Getting Started</a>
          </li>
          <li>
            <a
              href="/docs/mcp-server"
              class="text-sm text-slate-500 hover:text-slate-300 transition-colors"
              >MCP Server</a>
          </li>
          <li>
            <a
              href="/docs/local-api-server"
              class="text-sm text-slate-500 hover:text-slate-300 transition-colors"
              >Local API</a>
          </li>
        </ul>
      </div>

      <div>
        <h3
          class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3"
        >
          Community
        </h3>
        <ul class="space-y-2">
          <li>
            <a
              href="https://github.com/abhi16z/reqline.org"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-slate-500 hover:text-slate-300 transition-colors"
              >GitHub</a>
          </li>
          <li>
            <a
              href="https://github.com/abhi16z/ApiUnravel/issues"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-slate-500 hover:text-slate-300 transition-colors"
              >Issues</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-slate-800/60 text-center">
      <p class="text-xs text-slate-600">
        &copy; {year} Reqline. Built with Electron, React, and TypeScript.
      </p>
    </div>
  </div>
</footer>
