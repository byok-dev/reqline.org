---
import { RELEASE_URL } from '../data/urls';
---

<section class="relative overflow-hidden">
  <!-- Gradient background -->
  <div
    class="absolute inset-0 bg-gradient-to-b from-sky-500/5 via-transparent to-transparent"
  >
  </div>
  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-sky-500/5 rounded-full blur-3xl"
  >
  </div>

  <div
    class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-24 text-center"
  >
    <div
      class="inline-flex items-center gap-2 px-3 py-1 mb-6 bg-slate-900 border border-slate-800 rounded-full text-xs text-slate-400"
    >
      <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full"></span>
      Open source &middot; Cross-platform
    </div>

    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight">
      <span class="text-slate-100">A lightweight</span>
      <br />
      <span
        class="bg-gradient-to-r from-sky-400 to-sky-300 bg-clip-text text-transparent"
        >API testing client</span
      >
    </h1>

    <p
      class="mt-6 text-lg sm:text-xl text-slate-400 max-w-2xl mx-auto leading-relaxed"
    >
      Test and debug HTTP requests with a fast, focused desktop app. Built-in
      MCP server for AI-powered workflows. No bloat, no account required.
    </p>

    <div
      class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4"
    >
      <a
        href={RELEASE_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 bg-sky-500 hover:bg-sky-400 text-slate-950 font-semibold rounded-lg transition-colors text-sm"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
          ></path>
        </svg>
        Download
      </a>
      <a
        href="/docs/installation"
        class="inline-flex items-center gap-2 px-6 py-3 border border-slate-700 hover:border-slate-500 text-slate-300 hover:text-slate-100 font-medium rounded-lg transition-colors text-sm"
      >
        Read the Docs
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>

    <!-- App preview -->
    <div class="mt-16 relative">
      <div
        class="absolute -inset-4 bg-gradient-to-t from-slate-950 via-transparent to-transparent z-10 pointer-events-none"
      >
      </div>
      <div
        class="bg-slate-900 border border-slate-800 rounded-xl shadow-2xl shadow-sky-500/5 overflow-hidden p-1"
      >
        <div class="bg-slate-950 rounded-lg p-4">
          <!-- Simulated app UI -->
          <div class="flex items-center gap-2 mb-4">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
            </div>
            <div class="flex-1 flex items-center gap-2 ml-4">
              <span
                class="px-2 py-0.5 bg-emerald-500/20 text-emerald-400 text-xs font-mono font-semibold rounded"
                >GET</span
              >
              <div
                class="flex-1 bg-slate-900 border border-slate-800 rounded px-3 py-1.5 text-sm text-slate-400 font-mono"
              >
                https://api.example.com/users
              </div>
              <button
                class="px-4 py-1.5 bg-sky-500 text-slate-950 text-xs font-semibold rounded"
                >Send</button
              >
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div class="bg-slate-900 border border-slate-800 rounded p-3">
              <div class="flex gap-4 mb-2 text-xs">
                <span class="text-sky-400 border-b border-sky-400 pb-1"
                  >Params</span
                >
                <span class="text-slate-500">Headers</span>
                <span class="text-slate-500">Body</span>
                <span class="text-slate-500">Auth</span>
              </div>
              <div class="space-y-1.5">
                <div class="flex gap-2 text-xs">
                  <span class="text-slate-500 font-mono w-16">page</span>
                  <span class="text-slate-400 font-mono">1</span>
                </div>
                <div class="flex gap-2 text-xs">
                  <span class="text-slate-500 font-mono w-16">limit</span>
                  <span class="text-slate-400 font-mono">25</span>
                </div>
              </div>
            </div>
            <div class="bg-slate-900 border border-slate-800 rounded p-3">
              <div class="flex items-center justify-between mb-2">
                <div class="flex gap-4 text-xs">
                  <span class="text-sky-400 border-b border-sky-400 pb-1"
                    >Body</span
                  >
                  <span class="text-slate-500">Headers</span>
                </div>
                <div class="flex items-center gap-2 text-xs">
                  <span class="text-emerald-400">200 OK</span>
                  <span class="text-slate-600">124ms</span>
                </div>
              </div>
              <pre
                class="text-xs font-mono text-slate-400 leading-relaxed"><span class="text-slate-600">{"{"}</span>
  <span class="text-sky-300">"users"</span>: [
    {"{"} <span class="text-sky-300">"id"</span>: <span class="text-amber-400">1</span>, <span class="text-sky-300">"name"</span>: <span class="text-emerald-400">"Alice"</span> {"}"},
    {"{"} <span class="text-sky-300">"id"</span>: <span class="text-amber-400">2</span>, <span class="text-sky-300">"name"</span>: <span class="text-emerald-400">"Bob"</span> {"}"}
  ]
<span class="text-slate-600">{"}"}</span></pre>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
